# ─── Agent identity ──────────────────────────────────────────────────────
# What hostname this agent registers under in Redis. Defaults to system
# hostname. Override only if multiple agents share a system hostname
# (e.g. dev VMs cloned without changing hostname).
# AGENT_HOSTNAME=

# Where the agent listens for orchestrator commands.
AGENT_LISTEN_IP=0.0.0.0
AGENT_PORT=8090

# Shared secret with the orchestrator. ROTATE IN PRODUCTION.
AGENT_TOKEN=change-me

# ─── Redis (best-effort) ─────────────────────────────────────────────────
# If Redis is unreachable, the agent silently skips this heartbeat round
# and tries again on the next interval.
REDIS_URL=redis://control-plane.lan:6379
REDIS_TIMEOUT=2

# How often the agent reasserts host:<hostname> in Redis.
HEARTBEAT_INTERVAL=30

# How long Redis keeps the entry alive without a fresh heartbeat.
# Rule: HEARTBEAT_TTL > HEARTBEAT_INTERVAL × 2 to absorb one missed beat.
HEARTBEAT_TTL=60

# ─── DS container ────────────────────────────────────────────────────────
# Docker image the agent uses when the orchestrator asks for a spawn.
DS_DOCKER_IMAGE=mmorpg/dedicated_server:latest

# Label used to identify DS containers (for discovery on agent restart).
DS_IMAGE_LABEL=mmorpg.role=ds

# ─── Logging ─────────────────────────────────────────────────────────────
RUST_LOG=info