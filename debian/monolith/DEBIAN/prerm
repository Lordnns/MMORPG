#!/bin/sh
set -e

if [ "$1" = "remove" ] || [ "$1" = "upgrade" ]; then
    if systemctl is-active --quiet mmorpg-monolith.service; then
        echo "Stopping mmorpg-monolith..."
        systemctl stop mmorpg-monolith.service || true
    fi
fi

if [ "$1" = "remove" ]; then
    systemctl disable mmorpg-monolith.service || true
    # Clean up DS containers we may have spawned.
    DS=$(docker ps -aq --filter "label=mmorpg.role=ds" 2>/dev/null || true)
    if [ -n "$DS" ]; then
        echo "$DS" | xargs -r docker rm -f || true
    fi
fi

exit 0
